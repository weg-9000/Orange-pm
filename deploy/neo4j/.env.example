# Neo4j connection settings — copy this to .env and use it (.env is not tracked by git)
#   cp .env.example .env  then fill in the values

# -- docker compose (server side) --
NEO4J_PASSWORD=change-this-strong-password

# -- ingestion/search client (embed_pipeline / context_search) side --
# Either export the same .env, or set the same values in the client shell.
NEO4J_URI=bolt://<neo4j-server-ip>:7687
NEO4J_USER=neo4j
# Use the same NEO4J_PASSWORD value as above

# -- embedding model (local, no API key required by default) --
ORANGE_EMBED_MODEL=bge-m3
# To use an arbitrary HF model: ORANGE_EMBED_MODEL=<org/model> and ORANGE_EMBED_DIM=<dimension>
# To use Voyage cloud: ORANGE_EMBED_MODEL=voyage-3 + VOYAGE_API_KEY=...
