# Neo4j 접속 설정 — 복사해서 .env 로 사용(.env 는 git 미추적)
#   cp .env.example .env  후 값 채움

# ── docker compose(서버 측) ──
NEO4J_PASSWORD=change-this-strong-password

# ── 적재/검색 클라이언트(embed_pipeline / context_search) 측 ──
# 같은 .env 를 export 해서 쓰거나, 클라이언트 셸에 동일 값을 설정한다.
NEO4J_URI=bolt://<neo4j-server-ip>:7687
NEO4J_USER=neo4j
# NEO4J_PASSWORD 는 위와 동일 값 사용

# ── 임베딩 모델(로컬, 키 불요가 기본) ──
ORANGE_EMBED_MODEL=bge-m3
# 임의 HF 모델 사용 시: ORANGE_EMBED_MODEL=<org/model> 와 ORANGE_EMBED_DIM=<차원>
# Voyage 클라우드 사용 시: ORANGE_EMBED_MODEL=voyage-3 + VOYAGE_API_KEY=...
