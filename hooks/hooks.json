{
  "hooks": {

    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/_hook_guard.py\" SessionStart"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/_version_check.py\""
          }
        ]
      }
    ],

    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/ui_event_emit.py\" --hook UserPromptSubmit --from-stdin --hub-root ."
          }
        ]
      }
    ],

    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/_hook_guard.py\" Stop"
          }
        ]
      }
    ],

    "SubagentStop": [
      {
        "matcher": "researcher",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/_hook_guard.py\" SubagentStop researcher"
          }
        ]
      },
      {
        "matcher": "synthesizer",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/_hook_guard.py\" SubagentStop synthesizer"
          }
        ]
      },
      {
        "matcher": "explorer",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/_hook_guard.py\" SubagentStop explorer"
          }
        ]
      },
      {
        "matcher": "reviewer",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/_hook_guard.py\" SubagentStop reviewer"
          }
        ]
      },
      {
        "matcher": "integrator",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/_hook_guard.py\" SubagentStop integrator"
          }
        ]
      },
      {
        "matcher": "graph-generator",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/_hook_guard.py\" SubagentStop graph-generator"
          }
        ]
      }
    ],

    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/_hook_guard.py\" PostToolUse \"Edit|Write|MultiEdit\""
          },
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/auto_assemble_on_draft_edit.py\""
          },
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/journey_build.py\" --from-hook"
          },
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/ui_event_emit.py\" --hook PostToolUse --tool edit --hub-root ."
          }
        ]
      }
    ]

  }
}
